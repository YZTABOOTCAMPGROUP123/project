# StartMetrics backend ortam değişkenleri.
# Bu dosyayı .env olarak kopyalayıp doldurun. .env'i GIT'e EKLEMEYİN.
#
# Anahtar boş bırakılırsa uygulama yine çalışır: llm_client kural tabanlı
# "stub" raporu üretir (demo asla çökmez).

LLM_PROVIDER=openai

# --- OpenAI (varsayılan) ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- Alternatif: Anthropic (LLM_PROVIDER=anthropic yapın) ---
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-haiku-4-5

# --- Alternatif: Gemini (LLM_PROVIDER=gemini yapın) ---
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.5-flash

# --- Alternatif: OpenRouter (LLM_PROVIDER=openrouter yapın) ---
# OPENROUTER_API_KEY=
# OPENROUTER_MODEL=google/gemini-2.5-flash

